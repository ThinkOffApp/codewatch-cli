#!/bin/bash
# CodeWatch CLI - IDE notifications on your phone and watch
# https://codewatch.dev
#
# Usage: npx codewatch-cli connect
#        codewatch watch
#        codewatch status

set -euo pipefail

VERSION="1.0.0"
CODEWATCH_DIR="${HOME}/.codewatch"
CODEWATCH_CONFIG="${CODEWATCH_DIR}/config"
RELAY_URL="${CODEWATCH_RELAY_URL:-https://groupmind.one/api/v1/relay}"

# ── Helpers ──────────────────────────────────────────────────────────────

usage() {
    cat <<EOF
CodeWatch v${VERSION} - IDE notifications on your phone and watch

Usage:
  codewatch connect           Detect IDEs and install notification hooks
  codewatch watch             Start reply poller (delivers replies to your IDE)
  codewatch notify <message>  Send a test notification to your phone/watch
  codewatch status            Show connection status and installed hooks
  codewatch disconnect        Remove all CodeWatch hooks
  codewatch version           Show version

Get the app: https://codewatch.dev
EOF
}

load_config() {
    CODEWATCH_API_KEY=""
    CODEWATCH_USER_ID=""
    if [ -f "$CODEWATCH_CONFIG" ]; then
        while IFS='=' read -r key value; do
            key=$(echo "$key" | tr -d '[:space:]"')
            value=$(echo "$value" | sed 's/^"//;s/"$//' | tr -d "'")
            case "$key" in
                CODEWATCH_API_KEY)  CODEWATCH_API_KEY="$value" ;;
                CODEWATCH_USER_ID)  CODEWATCH_USER_ID="$value" ;;
            esac
        done < "$CODEWATCH_CONFIG"
    fi
}

save_config() {
    mkdir -p "$CODEWATCH_DIR"
    cat > "$CODEWATCH_CONFIG" <<CONF
CODEWATCH_API_KEY="${CODEWATCH_API_KEY}"
CODEWATCH_USER_ID="${CODEWATCH_USER_ID}"
CONF
    chmod 600 "$CODEWATCH_CONFIG"
}

require_config() {
    load_config
    if [ -z "${CODEWATCH_API_KEY:-}" ] || [ -z "${CODEWATCH_USER_ID:-}" ]; then
        echo "Not connected. Run: codewatch connect"
        exit 1
    fi
}

# JSON-safe string encoding via python3
json_encode() {
    python3 -c "import json,sys; print(json.dumps(sys.stdin.read().rstrip('\n')))" <<< "$1"
}

# ── IDE Detection ────────────────────────────────────────────────────────

detect_ides() {
    local ides=""

    # Claude Code
    if [ -d "$HOME/.claude" ] || command -v claude >/dev/null 2>&1; then
        ides="${ides:+$ides }claude-code"
    fi

    # Cursor
    if [ -d "$HOME/.cursor" ]; then
        ides="${ides:+$ides }cursor"
    fi

    # VS Code
    if [ -d "$HOME/.vscode" ] || command -v code >/dev/null 2>&1; then
        ides="${ides:+$ides }vscode"
    fi

    # Codex (OpenAI)
    if [ -d "$HOME/.codex" ] || command -v codex >/dev/null 2>&1; then
        ides="${ides:+$ides }codex"
    fi

    # Windsurf
    if [ -d "$HOME/.windsurf" ]; then
        ides="${ides:+$ides }windsurf"
    fi

    # Aider
    if command -v aider >/dev/null 2>&1; then
        ides="${ides:+$ides }aider"
    fi

    echo "$ides"
}

# ── Hook Generation ─────────────────────────────────────────────────────

# Writes a per-IDE hook script that POSTs notifications to the relay.
# Uses python3 for proper JSON encoding (handles special chars in body).
write_hook_script() {
    local source_name="$1"
    local hook_script="${CODEWATCH_DIR}/${source_name}-hook.sh"
    mkdir -p "$CODEWATCH_DIR"

    cat > "$hook_script" <<'HOOKEOF'
#!/bin/bash
# CodeWatch hook for __SOURCE__
# Auto-generated by codewatch connect. Do not edit.
CODEWATCH_API_KEY=""
CODEWATCH_USER_ID=""
if [ -f "${HOME}/.codewatch/config" ]; then
    while IFS='=' read -r key value; do
        key=$(echo "$key" | tr -d '[:space:]"')
        value=$(echo "$value" | sed 's/^"//;s/"$//' | tr -d "'")
        case "$key" in
            CODEWATCH_API_KEY)  CODEWATCH_API_KEY="$value" ;;
            CODEWATCH_USER_ID)  CODEWATCH_USER_ID="$value" ;;
        esac
    done < "${HOME}/.codewatch/config"
fi
[ -z "${CODEWATCH_API_KEY:-}" ] && exit 0
[ -z "${CODEWATCH_USER_ID:-}" ] && exit 0

export CODEWATCH_API_KEY CODEWATCH_USER_ID
RELAY_URL="${CODEWATCH_RELAY_URL:-https://groupmind.one/api/v1/relay}"
export RELAY_URL
HOOK_EVENT="${CLAUDE_HOOK_EVENT:-unknown}"

case "$HOOK_EVENT" in
    Notification)
        TITLE="__SOURCE__ notification"
        REPLY_TARGET="__SOURCE__"
        ;;
    Stop)
        TITLE="__SOURCE__ finished"
        REPLY_TARGET=""
        ;;
    *)
        exit 0
        ;;
esac

BODY=""
if [ ! -t 0 ]; then
    BODY=$(head -c 2000)
fi

# Use python3 for proper JSON encoding (handles quotes, newlines, unicode)
python3 -c "
import json, urllib.request, sys, os
data = json.dumps({
    'user_id': os.environ.get('CODEWATCH_USER_ID', ''),
    'title': '$TITLE',
    'source': '__SOURCE__@' + os.popen('hostname -s').read().strip(),
    'event_type': 'agent',
    'body': sys.stdin.read()[:500],
    'reply_target': '$REPLY_TARGET'
}).encode()
req = urllib.request.Request(
    os.environ.get('RELAY_URL', 'https://groupmind.one/api/v1/relay') + '/events',
    data=data,
    headers={
        'X-API-Key': os.environ.get('CODEWATCH_API_KEY', ''),
        'Content-Type': 'application/json'
    }
)
try:
    urllib.request.urlopen(req, timeout=5)
except:
    pass
" <<< "$BODY" &
HOOKEOF

    # Replace __SOURCE__ placeholder (compatible with macOS and Linux)
    if [[ "$OSTYPE" == "darwin"* ]]; then
        sed -i '' "s/__SOURCE__/${source_name}/g" "$hook_script"
    else
        sed -i "s/__SOURCE__/${source_name}/g" "$hook_script"
    fi
    chmod +x "$hook_script"
    echo "$hook_script"
}

# ── Hook Installation (per IDE) ─────────────────────────────────────────

install_claude_hook() {
    local hook_script
    hook_script=$(write_hook_script "claude-code")

    local settings_file="${HOME}/.claude/settings.json"
    if [ ! -f "$settings_file" ]; then
        mkdir -p "$(dirname "$settings_file")"
        echo '{}' > "$settings_file"
    fi

    python3 -c "
import json, sys
settings_file = '$settings_file'
hook_script = '$hook_script'
with open(settings_file, 'r') as f:
    settings = json.load(f)
hooks = settings.get('hooks', {})
hook_entry = {'type': 'command', 'command': hook_script}
for event in ['Notification', 'Stop']:
    event_hooks = hooks.get(event, [])
    if not any(h.get('command') == hook_script for h in event_hooks):
        event_hooks.append(hook_entry)
    hooks[event] = event_hooks
settings['hooks'] = hooks
with open(settings_file, 'w') as f:
    json.dump(settings, f, indent=2)
" 2>/dev/null
    echo "  [ok] Claude Code: hooks installed in settings.json"
}

install_codex_hook() {
    local hook_script
    hook_script=$(write_hook_script "codex")

    local settings_file="${HOME}/.codex/settings.json"
    if [ ! -f "$settings_file" ]; then
        mkdir -p "$(dirname "$settings_file")"
        echo '{}' > "$settings_file"
    fi

    python3 -c "
import json
settings_file = '$settings_file'
hook_script = '$hook_script'
with open(settings_file, 'r') as f:
    settings = json.load(f)
hooks = settings.get('hooks', {})
hook_entry = {'type': 'command', 'command': hook_script}
for event in ['Notification', 'Stop']:
    event_hooks = hooks.get(event, [])
    if not any(h.get('command') == hook_script for h in event_hooks):
        event_hooks.append(hook_entry)
    hooks[event] = event_hooks
settings['hooks'] = hooks
with open(settings_file, 'w') as f:
    json.dump(settings, f, indent=2)
" 2>/dev/null
    echo "  [ok] Codex: hooks installed in settings.json"
}

install_cursor_hook() {
    local hook_script
    hook_script=$(write_hook_script "cursor")
    echo "  [ok] Cursor: hook ready at $hook_script"
    echo "       Add to Cursor tasks or terminal profile to activate"
}

install_vscode_hook() {
    local hook_script
    hook_script=$(write_hook_script "vscode")
    echo "  [ok] VS Code: hook ready at $hook_script"
    echo "       Add as a VS Code task or call from terminal"
}

install_windsurf_hook() {
    local hook_script
    hook_script=$(write_hook_script "windsurf")
    echo "  [ok] Windsurf: hook ready at $hook_script"
}

install_aider_hook() {
    local hook_script
    hook_script=$(write_hook_script "aider")
    echo "  [ok] Aider: hook ready at $hook_script"
    echo "       Use with: aider --message-hook $hook_script"
}

# ── Commands ─────────────────────────────────────────────────────────────

cmd_connect() {
    echo ""
    echo "  CodeWatch Connect"
    echo "  ================="
    echo ""

    # Detect IDEs
    local ides
    ides=$(detect_ides)
    local ide_count
    ide_count=$(echo "$ides" | wc -w | tr -d ' ')

    if [ -z "$ides" ]; then
        echo "  No supported IDEs detected."
        echo "  Supported: Claude Code, Cursor, VS Code, Codex, Windsurf, Aider"
        echo ""
        echo "  You can still use: codewatch notify <message>"
        echo ""
        ide_count=0
    else
        echo "  Detected $ide_count IDE(s): $ides"
        echo ""
    fi

    # Check existing config
    load_config
    if [ -n "${CODEWATCH_API_KEY:-}" ] && [ -n "${CODEWATCH_USER_ID:-}" ]; then
        echo "  Already connected as: ${CODEWATCH_USER_ID}"
        echo ""
        read -p "  Reconfigure? [y/N] " -n 1 -r
        echo
        if [[ ! ${REPLY:-} =~ ^[Yy]$ ]]; then
            echo ""
            echo "  Installing hooks..."
            install_hooks "$ides"
            echo ""
            echo "  Done! $ide_count IDE(s) connected."
            echo "  Run 'codewatch watch' to receive replies."
            return 0
        fi
    fi

    # Get credentials
    echo "  Enter your CodeWatch API key"
    echo "  (get one at https://codewatch.dev or from the app)"
    echo ""
    read -p "  API key: " api_key
    if [ -z "$api_key" ]; then
        echo "  Error: API key is required"
        exit 1
    fi

    read -p "  User ID (your handle or email): " user_id
    if [ -z "$user_id" ]; then
        echo "  Error: User ID is required"
        exit 1
    fi

    CODEWATCH_API_KEY="$api_key"
    CODEWATCH_USER_ID="$user_id"
    save_config
    echo ""
    echo "  Config saved."
    echo ""

    # Install hooks
    echo "  Installing hooks..."
    install_hooks "$ides"
    echo ""

    # Test connection
    echo "  Testing connection..."
    local http_code
    http_code=$(CODEWATCH_USER_ID="$user_id" CODEWATCH_API_KEY="$api_key" \
      CODEWATCH_RELAY_URL="$RELAY_URL" CODEWATCH_IDE_COUNT="$ide_count" \
      CODEWATCH_IDES="${ides:-none}" python3 -c "
import json, urllib.request, os
data = json.dumps({
    'user_id': os.environ['CODEWATCH_USER_ID'],
    'title': 'CodeWatch connected!',
    'source': 'codewatch-cli',
    'event_type': 'agent',
    'severity': 'info',
    'body': 'Connected ' + os.environ['CODEWATCH_IDE_COUNT'] + ' IDE(s): ' + os.environ['CODEWATCH_IDES']
}).encode()
req = urllib.request.Request(
    os.environ['CODEWATCH_RELAY_URL'] + '/events',
    data=data,
    headers={'X-API-Key': os.environ['CODEWATCH_API_KEY'], 'Content-Type': 'application/json'}
)
try:
    resp = urllib.request.urlopen(req, timeout=10)
    print(resp.getcode())
except Exception as e:
    if hasattr(e, 'code'):
        print(e.code)
    else:
        print('0')
" 2>/dev/null)

    if [ "$http_code" = "201" ]; then
        echo "  Connection successful! Test notification sent to your phone."
    else
        echo "  Warning: got HTTP $http_code. Check your API key."
    fi

    echo ""
    echo "  Done! $ide_count IDE(s) connected."
    echo ""
    echo "  Next steps:"
    echo "    1. Install the CodeWatch app on your phone/watch"
    echo "    2. Run 'codewatch watch' to receive replies from your phone"
    echo ""
}

install_hooks() {
    local ides="$1"
    for ide in $ides; do
        case "$ide" in
            claude-code) install_claude_hook ;;
            cursor)      install_cursor_hook ;;
            vscode)      install_vscode_hook ;;
            codex)       install_codex_hook ;;
            windsurf)    install_windsurf_hook ;;
            aider)       install_aider_hook ;;
        esac
    done
}

cmd_watch() {
    require_config

    echo ""
    echo "  CodeWatch Reply Poller v${VERSION}"
    echo "  =================================="
    echo ""

    # Build tmux session map
    local session_map=""
    if command -v tmux >/dev/null 2>&1; then
        for session in $(tmux list-sessions -F '#{session_name}' 2>/dev/null); do
            case "$session" in
                claude*)   session_map="${session_map:+$session_map }claude-code:$session" ;;
                codex*)    session_map="${session_map:+$session_map }codex:$session" ;;
                aider*)    session_map="${session_map:+$session_map }aider:$session" ;;
                windsurf*) session_map="${session_map:+$session_map }windsurf:$session" ;;
            esac
        done
    fi

    if [ -n "$session_map" ]; then
        echo "  IDE sessions found:"
        for mapping in $session_map; do
            echo "    ${mapping%%:*} -> tmux:${mapping#*:}"
        done
    else
        echo "  No tmux IDE sessions found."
        echo "  Replies will show as desktop notifications."
    fi

    local seen_file="${CODEWATCH_DIR}/seen_replies.txt"
    touch "$seen_file"

    echo ""
    echo "  Polling every 5s... (Ctrl+C to stop)"
    echo ""

    while true; do
        local events
        events=$(curl -sf \
            -H "X-API-Key: ${CODEWATCH_API_KEY}" \
            "${RELAY_URL}/events/${CODEWATCH_USER_ID}?limit=20" 2>/dev/null) || true

        if [ -n "$events" ]; then
            echo "$events" | python3 -c "
import json, sys, subprocess, os

seen_file = '$seen_file'
session_map_str = '$session_map'

session_map = {}
for pair in session_map_str.split():
    if ':' in pair:
        ide, sess = pair.split(':', 1)
        session_map[ide] = sess

try:
    data = json.load(sys.stdin)
except:
    sys.exit(0)

events = data.get('events', data if isinstance(data, list) else [])

seen = set()
if os.path.exists(seen_file):
    with open(seen_file) as f:
        seen = set(line.strip() for line in f if line.strip())

for event in events:
    eid = event.get('id', '')
    reply = event.get('reply_text')
    replied_at = event.get('replied_at')
    source = event.get('source', '')
    title = event.get('title', '')
    body = event.get('body', '')
    event_type = event.get('event_type', '')

    # Handle replies to notifications
    if reply and replied_at:
        if reply.strip().lower() in ('dismiss', 'dismissed', 'read', ''):
            continue
        reply_key = f'{eid}:{replied_at}'
        if reply_key in seen:
            continue
        seen.add(reply_key)
        with open(seen_file, 'a') as f:
            f.write(reply_key + '\n')
        text = reply
        label = f'Reply to \"{title}\"'

    # Handle new messages from app (plus button / compose)
    elif source in ('codewatch-app', 'codewatch-watch') and (body or title):
        msg_key = f'{eid}:msg'
        if msg_key in seen:
            continue
        seen.add(msg_key)
        with open(seen_file, 'a') as f:
            f.write(msg_key + '\n')
        text = body or title
        label = 'Task from phone'

    else:
        continue

    # Extract IDE name from source (e.g. 'claude-code@hostname' -> 'claude-code')
    ide_name = source.split('@')[0] if '@' in source else source

    print(f'  [{source}] {label}: {text}')

    # For app messages, try all IDE sessions (prefer claude-code)
    if source in ('codewatch-app', 'codewatch-watch'):
        tmux_session = session_map.get('claude-code') or (list(session_map.values())[0] if session_map else None)
    else:
        tmux_session = session_map.get(ide_name)

    if tmux_session:
        try:
            result = subprocess.run(
                ['tmux', 'has-session', '-t', tmux_session],
                capture_output=True, timeout=2
            )
            if result.returncode == 0:
                subprocess.run(
                    ['tmux', 'send-keys', '-t', tmux_session, reply, 'Enter'],
                    capture_output=True, timeout=2
                )
                print(f'    -> Injected into tmux:{tmux_session}')
        except Exception:
            pass

    # Desktop notification (macOS)
    try:
        safe_title = label.replace('\"', '').replace(\"'\", '')[:60]
        safe_text = text.replace('\"', '').replace(\"'\", '')[:200]
        subprocess.run(
            ['osascript', '-e',
             f'display notification \"{safe_text}\" with title \"CodeWatch\" subtitle \"{safe_title}\"'],
            capture_output=True, timeout=2
        )
    except Exception:
        pass

    # Linux notification
    try:
        subprocess.run(
            ['notify-send', 'CodeWatch: ' + label[:60], text[:200]],
            capture_output=True, timeout=2
        )
    except FileNotFoundError:
        pass
" 2>/dev/null
        fi

        sleep 5
    done
}

cmd_notify() {
    require_config

    local message="${*:-Test notification from CodeWatch}"

    local http_code
    http_code=$(CODEWATCH_USER_ID="$CODEWATCH_USER_ID" CODEWATCH_API_KEY="$CODEWATCH_API_KEY" \
      CODEWATCH_RELAY_URL="$RELAY_URL" python3 -c "
import json, urllib.request, sys, os
data = json.dumps({
    'user_id': os.environ['CODEWATCH_USER_ID'],
    'title': sys.argv[1],
    'source': 'codewatch-cli',
    'event_type': 'custom',
    'severity': 'info',
    'reply_target': 'codewatch-cli'
}).encode()
req = urllib.request.Request(
    os.environ['CODEWATCH_RELAY_URL'] + '/events',
    data=data,
    headers={'X-API-Key': os.environ['CODEWATCH_API_KEY'], 'Content-Type': 'application/json'}
)
try:
    resp = urllib.request.urlopen(req, timeout=10)
    print(resp.getcode())
except Exception as e:
    print(getattr(e, 'code', 0))
" "$message" 2>/dev/null)

    if [ "$http_code" = "201" ]; then
        echo "Notification sent: $message"
    else
        echo "Failed (HTTP $http_code). Check: codewatch status"
    fi
}

cmd_status() {
    load_config
    echo ""
    echo "  CodeWatch Status"
    echo "  ================"
    echo ""

    if [ -z "${CODEWATCH_API_KEY:-}" ]; then
        echo "  Not connected. Run: codewatch connect"
        return
    fi

    echo "  User:   ${CODEWATCH_USER_ID}"
    echo "  Relay:  ${RELAY_URL}"
    echo "  Config: ${CODEWATCH_CONFIG}"
    echo ""

    # Detected IDEs
    local ides
    ides=$(detect_ides)
    echo "  Detected IDEs: ${ides:-none}"
    echo ""

    # Installed hooks
    local hook_count=0
    echo "  Installed hooks:"
    for f in "${CODEWATCH_DIR}"/*-hook.sh; do
        if [ -f "$f" ]; then
            echo "    $(basename "$f")"
            hook_count=$((hook_count + 1))
        fi
    done
    if [ "$hook_count" -eq 0 ]; then
        echo "    (none)"
    fi
    echo ""

    # Reply poller
    if pgrep -f "codewatch watch" >/dev/null 2>&1; then
        echo "  Reply poller: running (PID $(pgrep -f 'codewatch watch' | head -1))"
    else
        echo "  Reply poller: not running"
        echo "                Start with: codewatch watch"
    fi
    echo ""

    # Test relay
    echo "  Testing relay..."
    local http_code
    http_code=$(curl -sf -o /dev/null -w "%{http_code}" \
        -H "X-API-Key: ${CODEWATCH_API_KEY}" \
        "${RELAY_URL}/events/${CODEWATCH_USER_ID}?limit=1" 2>/dev/null) || http_code="0"
    if [ "$http_code" = "200" ]; then
        echo "  Relay: connected (HTTP 200)"
    else
        echo "  Relay: error (HTTP $http_code)"
    fi
    echo ""
}

cmd_disconnect() {
    echo ""
    echo "  Removing CodeWatch hooks..."

    # Remove from Claude Code settings.json
    local settings_file="${HOME}/.claude/settings.json"
    if [ -f "$settings_file" ]; then
        python3 -c "
import json, os
sf = '$settings_file'
hd = os.path.expanduser('~/.codewatch')
with open(sf) as f: s = json.load(f)
h = s.get('hooks', {})
for e in list(h.keys()):
    h[e] = [x for x in h[e] if not x.get('command','').startswith(hd)]
    if not h[e]: del h[e]
s['hooks'] = h
with open(sf,'w') as f: json.dump(s, f, indent=2)
" 2>/dev/null && echo "  [ok] Claude Code hooks removed"
    fi

    # Remove from Codex settings.json
    local codex_settings="${HOME}/.codex/settings.json"
    if [ -f "$codex_settings" ]; then
        python3 -c "
import json, os
sf = '$codex_settings'
hd = os.path.expanduser('~/.codewatch')
with open(sf) as f: s = json.load(f)
h = s.get('hooks', {})
for e in list(h.keys()):
    h[e] = [x for x in h[e] if not x.get('command','').startswith(hd)]
    if not h[e]: del h[e]
s['hooks'] = h
with open(sf,'w') as f: json.dump(s, f, indent=2)
" 2>/dev/null && echo "  [ok] Codex hooks removed"
    fi

    # Remove hook scripts
    rm -f "${CODEWATCH_DIR}"/*-hook.sh 2>/dev/null
    echo "  [ok] Hook scripts removed"

    echo ""
    echo "  CodeWatch disconnected."
    echo "  Config kept at $CODEWATCH_CONFIG (delete manually if needed)."
    echo ""
}

cmd_version() {
    echo "codewatch v${VERSION}"
}

# ── Main ─────────────────────────────────────────────────────────────────

case "${1:-}" in
    connect)    cmd_connect ;;
    watch)      cmd_watch ;;
    notify)     shift; cmd_notify "$@" ;;
    status)     cmd_status ;;
    disconnect) cmd_disconnect ;;
    version|-v|--version) cmd_version ;;
    -h|--help)  usage ;;
    "")         usage ;;
    *)
        echo "Unknown command: $1"
        echo "Run 'codewatch --help' for usage."
        exit 1
        ;;
esac
